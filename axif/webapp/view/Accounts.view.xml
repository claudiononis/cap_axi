<mvc:View
    controllerName="axi.axif.controller.Accounts"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page showHeader="false" enableScrolling="true" busy="{accountsView>/busy}">
        <content>
            <VBox class="sapUiResponsiveContentPadding sapUiMediumMarginBottom">
                <OverflowToolbar class="sapUiTinyMarginBottom">
                    <Title text="Accounts" level="H3" />
                    <ToolbarSpacer />
                    <Button text="Nueva regla" press=".onNewRule" />
                    <Button
                        text="Editar"
                        press=".onEditRule"
                        enabled="{= ${accountsView>/selectedRulePath} ? !${accountsView>/isEditMode} : false }" />
                    <Button
                        text="Guardar"
                        type="Emphasized"
                        press=".onSaveRule"
                        enabled="{accountsView>/isEditMode}" />
                    <Button
                        text="Cancelar"
                        press=".onCancelRule"
                        enabled="{accountsView>/isEditMode}" />
                </OverflowToolbar>

                <MessageStrip
                    text="Determinacion contable AxI consumiendo AccountRules por OData. Las cuentas no monetarias alimentan la simulacion del Cockpit."
                    type="Information"
                    showIcon="true"
                    class="sapUiTinyMarginBottom" />

                <HBox wrap="Wrap" class="sapUiTinyMarginBottom">
                    <GenericTile header="Reglas" subheader="Total">
                        <TileContent>
                            <NumericContent value="{accountsView>/summary/total}" />
                        </TileContent>
                    </GenericTile>
                    <GenericTile header="Activas" subheader="Disponibles" class="sapUiTinyMarginBegin">
                        <TileContent>
                            <NumericContent value="{accountsView>/summary/active}" valueColor="Good" />
                        </TileContent>
                    </GenericTile>
                    <GenericTile header="No monetarias" subheader="Simulables" class="sapUiTinyMarginBegin">
                        <TileContent>
                            <NumericContent value="{accountsView>/summary/nonMonetary}" valueColor="Information" />
                        </TileContent>
                    </GenericTile>
                </HBox>

                <HBox wrap="Wrap" renderType="Bare" alignItems="Start">
                    <Panel headerText="Reglas contables AxI" width="24rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                        <List
                            id="rulesList"
                            mode="SingleSelectMaster"
                            includeItemInSelection="true"
                            selectionChange=".onRuleSelectionChange"
                            items="{accounts>/rules}">
                            <items>
                                <ObjectListItem
                                    title="{accounts>glAccount}"
                                    number="{accounts>ledger}"
                                    numberUnit="{accounts>companyCode}"
                                    intro="{accounts>ruleId}">
                                    <firstStatus>
                                        <ObjectStatus
                                            text="{accounts>classification}"
                                            state="{= ${accounts>classification} === 'NON_MONETARY' ? 'Information' : 'Success' }" />
                                    </firstStatus>
                                    <secondStatus>
                                        <ObjectStatus
                                            text="{= ${accounts>active} ? 'Activa' : 'Inactiva' }"
                                            state="{= ${accounts>active} ? 'Success' : 'Error' }" />
                                    </secondStatus>
                                    <attributes>
                                        <ObjectAttribute text="{accounts>description}" />
                                        <ObjectAttribute text="{= 'Vigencia ' + ${accounts>validFrom} + ' a ' + ${accounts>validTo} }" />
                                    </attributes>
                                </ObjectListItem>
                            </items>
                        </List>
                    </Panel>

                    <Panel headerText="Detalle contable" expandable="false" class="sapUiSmallMarginBottom" width="calc(100% - 25rem)">
                        <VBox class="sapUiSmallMargin">
                            <HBox wrap="Wrap" justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
                                <VBox>
                                    <Title text="Cabecera de regla" level="H4" />
                                    <Text text="Mapeo de cuentas base, cuenta AxI, cuenta puente y RECPAM persistido en backend." />
                                </VBox>
                                <VBox alignItems="End">
                                    <ObjectStatus
                                        text="{= ${accountsView>/draftRule/active} ? 'Regla activa' : 'Regla inactiva' }"
                                        state="{= ${accountsView>/draftRule/active} ? 'Success' : 'Error' }" />
                                    <Text text="{= ${accountsView>/isEditMode} ? 'Modo edicion' : 'Modo visualizacion' }" />
                                </VBox>
                            </HBox>

                            <HBox wrap="Wrap" renderType="Bare">
                                <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="14rem">
                                    <Label text="Rule ID" required="true" />
                                    <Input value="{accountsView>/draftRule/ruleId}" editable="{accountsView>/isEditMode}" />
                                </VBox>
                                <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="14rem">
                                    <Label text="GL Account" required="true" />
                                    <Input value="{accountsView>/draftRule/glAccount}" editable="{accountsView>/isEditMode}" />
                                </VBox>
                                <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="24rem">
                                    <Label text="Descripcion" />
                                    <Input value="{accountsView>/draftRule/description}" editable="{accountsView>/isEditMode}" />
                                </VBox>
                            </HBox>

                            <HBox wrap="Wrap" renderType="Bare">
                                <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="10rem">
                                    <Label text="Company Code" required="true" />
                                    <Input value="{accountsView>/draftRule/companyCode}" editable="{accountsView>/isEditMode}" />
                                </VBox>
                                <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="8rem">
                                    <Label text="Ledger" required="true" />
                                    <Input value="{accountsView>/draftRule/ledger}" editable="{accountsView>/isEditMode}" />
                                </VBox>
                                <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="12rem">
                                    <Label text="Clasificacion" required="true" />
                                    <Select selectedKey="{accountsView>/draftRule/classification}" enabled="{accountsView>/isEditMode}">
                                        <items>
                                            <core:Item key="NON_MONETARY" text="NON_MONETARY" />
                                            <core:Item key="MONETARY" text="MONETARY" />
                                        </items>
                                    </Select>
                                </VBox>
                                <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="10rem">
                                    <Label text="Categoria" />
                                    <Select selectedKey="{accountsView>/draftRule/category}" enabled="{accountsView>/isEditMode}">
                                        <items>
                                            <core:Item key="BS" text="Balance Sheet" />
                                            <core:Item key="PL" text="Profit and Loss" />
                                        </items>
                                    </Select>
                                </VBox>
                                <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="8rem">
                                    <Label text="Activa" />
                                    <Switch state="{accountsView>/draftRule/active}" enabled="{accountsView>/isEditMode}" />
                                </VBox>
                            </HBox>

                            <Panel headerText="Determinacion de cuentas" class="sapUiTinyMarginTop sapUiSmallMarginBottom">
                                <VBox class="sapUiSmallMargin">
                                    <HBox wrap="Wrap" renderType="Bare">
                                        <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="14rem">
                                            <Label text="Cuenta AxI" />
                                            <Input value="{accountsView>/draftRule/adjustmentAccount}" editable="{accountsView>/isEditMode}" />
                                        </VBox>
                                        <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="14rem">
                                            <Label text="Cuenta puente" />
                                            <Input value="{accountsView>/draftRule/offsetAccount}" editable="{accountsView>/isEditMode}" />
                                        </VBox>
                                        <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="14rem">
                                            <Label text="Cuenta RECPAM" required="true" />
                                            <Input value="{accountsView>/draftRule/recpamAccount}" editable="{accountsView>/isEditMode}" />
                                        </VBox>
                                        <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="10rem">
                                            <Label text="Doc Type" />
                                            <Input value="{accountsView>/draftRule/documentType}" editable="{accountsView>/isEditMode}" />
                                        </VBox>
                                        <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="10rem">
                                            <Label text="Factor mock" />
                                            <Input value="{accountsView>/draftRule/simulationFactor}" editable="{accountsView>/isEditMode}" />
                                        </VBox>
                                    </HBox>
                                </VBox>
                            </Panel>

                            <Panel headerText="Vigencia" class="sapUiSmallMarginBottom">
                                <VBox class="sapUiSmallMargin">
                                    <HBox wrap="Wrap" renderType="Bare">
                                        <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="12rem">
                                            <Label text="Valid From" />
                                            <DatePicker
                                                value="{accountsView>/draftRule/validFrom}"
                                                valueFormat="yyyy-MM-dd"
                                                displayFormat="medium"
                                                editable="{accountsView>/isEditMode}" />
                                        </VBox>
                                        <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="12rem">
                                            <Label text="Valid To" />
                                            <DatePicker
                                                value="{accountsView>/draftRule/validTo}"
                                                valueFormat="yyyy-MM-dd"
                                                displayFormat="medium"
                                                editable="{accountsView>/isEditMode}" />
                                        </VBox>
                                    </HBox>
                                </VBox>
                            </Panel>
                        </VBox>
                    </Panel>
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>
